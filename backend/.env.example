# ============================================
# CONFIGURACIÓN DE APIS
# ============================================

# Deepgram - Speech-to-Text (obtener en https://console.deepgram.com)
DEEPGRAM_API_KEY=tu_deepgram_api_key_aqui

# OpenAI - LLM para extracción (obtener en https://platform.openai.com)
OPENAI_API_KEY=sk-proj-...

# ============================================
# MODELOS A USAR
# ============================================
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi
LLM_MODEL=gpt-4o-mini

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
HOST=127.0.0.1
PORT=8000
DEBUG=True

# ============================================
# CONFIGURACIÓN DE PROCESAMIENTO
# ============================================
MAX_AUDIO_DURATION_SECONDS=900
ALLOWED_AUDIO_FORMATS=webm,mp3,wav,m4a,ogg
